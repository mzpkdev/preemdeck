{
  "name": "directive",
  "version": "0.0.0",
  "description": "Swappable behavioral directive. A /directive command picks which directive a per-prompt hook injects as context.",
  "hooks": {
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.preemdeck/preemdeck-runtime \"$HOME/.preemdeck/src/ripperdoc/wetware/directive/scripts/inject-mode.ts\" --event UserPromptSubmit",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
