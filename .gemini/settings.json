{
  "model": {
    "name": "gemini-2.5-pro"
  },
  "hooks": {
    "AfterTool": [
      {
        "matcher": "(write_.*|replace|edit)",
        "hooks": [
          {
            "type": "command",
            "command": "\"${GEMINI_PROJECT_DIR}/preemdeck-runtime\" \"${GEMINI_PROJECT_DIR}/devscripts/format-on-edit.ts\"",
            "timeout": 30
          }
        ]
      }
    ]
  }
}
