{
  "name": "os",
  "version": "0.1.0",
  "description": "Cross-platform system sound and desktop notifications; dings on turn end",
  "hooks": {
    "AfterAgent": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.preemdeck/scripts/preemdeck-bun \"${extensionPath}/toolbox/os_ding.ts\"",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
