{
  "name": "os",
  "description": "Cross-platform system sound and desktop notifications; dings on turn end",
  "version": "0.1.0",
  "author": {
    "name": "preemdeck"
  },
  "keywords": [
    "dock",
    "os"
  ],
  "hooks": {
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.preemdeck/scripts/preemdeck-bun \"${CLAUDE_PLUGIN_ROOT}/toolbox/os_ding.ts\"",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
