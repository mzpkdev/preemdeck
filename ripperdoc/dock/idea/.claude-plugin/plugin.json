{
  "name": "idea",
  "description": "Auto-open specs, briefs, and plans in the correct JetBrains IDE",
  "version": "0.0.0",
  "author": {
    "name": "preemdeck"
  },
  "keywords": [
    "dock",
    "jetbrains",
    "ide",
    "auto-open",
    "acp"
  ],
  "hooks": {
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.preemdeck/scripts/preemdeck-bun \"${CLAUDE_PLUGIN_ROOT}/toolbox/turn-notify.ts\" Claude",
            "timeout": 5
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "ExitPlanMode",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.preemdeck/scripts/preemdeck-bun \"${CLAUDE_PLUGIN_ROOT}/toolbox/plan-preview.ts\"",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
