{
  "name": "idea",
  "version": "0.1.0",
  "description": "Auto-open specs, briefs, and plans in the correct JetBrains IDE",
  "hooks": {
    "AfterAgent": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.preemdeck/scripts/preemdeck-bun \"${extensionPath}/toolbox/turn-notify.ts\" Gemini",
            "timeout": 5
          }
        ]
      }
    ],
    "BeforeTool": [
      {
        "matcher": "exit_plan_mode",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.preemdeck/scripts/preemdeck-bun \"${extensionPath}/toolbox/plan-preview.ts\"",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
