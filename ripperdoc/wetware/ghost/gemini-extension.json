{
  "name": "ghost",
  "version": "0.0.0",
  "description": "Persona engine. Injects engram, firmware, and pulse context on session start and each prompt.",
  "hooks": {
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.preemdeck/scripts/preemdeck-bun \"${extensionPath}/scripts/boot.ts\"",
            "timeout": 5
          }
        ]
      }
    ],
    "BeforeAgent": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.preemdeck/scripts/preemdeck-bun \"${extensionPath}/scripts/pulse.ts\"",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
