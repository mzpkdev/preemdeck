{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.preemdeck/scripts/preemdeck-bun \"$HOME/.preemdeck/ripperdoc/wetware/ghost/scripts/boot.ts\"",
            "timeout": 5
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.preemdeck/scripts/preemdeck-bun \"$HOME/.preemdeck/ripperdoc/wetware/ghost/scripts/pulse.ts\"",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
