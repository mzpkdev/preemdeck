{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.preemdeck/scripts/preemdeck-bun \"${PLUGIN_ROOT}/scripts/boot.ts\"",
            "timeout": 5
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.preemdeck/scripts/preemdeck-bun \"${PLUGIN_ROOT}/scripts/pulse.ts\"",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
