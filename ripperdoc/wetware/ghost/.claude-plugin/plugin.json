{
  "name": "ghost",
  "description": "Persona engine. Injects engram, firmware, and pulse context on session start and each prompt.",
  "version": "0.1.0",
  "author": {
    "name": "preemdeck"
  },
  "keywords": [
    "wetware",
    "persona",
    "engram",
    "firmware",
    "identity",
    "ghost"
  ],
  "hooks": {
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/scripts/boot.py",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/scripts/rapport.py",
            "timeout": 5
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/scripts/pulse.py",
            "timeout": 5
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ${CLAUDE_PLUGIN_ROOT}/scripts/engrave.py claude claude-haiku-4-5",
            "timeout": 30,
            "async": true
          }
        ]
      }
    ]
  }
}
