{
  "name": "imprint",
  "description": "Per-prompt behavioral imprints. Wetware burn-in for cross-host agents.",
  "version": "0.1.0",
  "author": {
    "name": "preemdeck"
  },
  "keywords": [
    "wetware",
    "prompt",
    "directive",
    "behavior",
    "imprint"
  ],
  "hooks": {
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/scripts/inject_hook.py IMPRINT.md hosts/host_claude.md --event UserPromptSubmit",
            "timeout": 5
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/scripts/notice_hook.py",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
