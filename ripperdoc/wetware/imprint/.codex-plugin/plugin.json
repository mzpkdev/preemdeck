{
  "name": "imprint",
  "description": "Per-prompt behavioral imprints. Wetware burn-in for cross-host agents.",
  "version": "0.0.0",
  "author": {
    "name": "preemdeck"
  },
  "keywords": [
    "wetware",
    "prompt",
    "directive",
    "behavior",
    "imprint"
  ],
  "hooks": {
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.preemdeck/scripts/preemdeck-bun \"$HOME/.preemdeck/ripperdoc/wetware/imprint/scripts/inject-hook.ts\" IMPRINT.md hosts/host_codex.md --event UserPromptSubmit",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
