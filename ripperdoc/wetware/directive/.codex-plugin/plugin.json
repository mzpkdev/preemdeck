{
  "name": "directive",
  "version": "0.1.0",
  "description": "Swappable behavioral directive. A /directive command picks which directive a per-prompt hook injects as context.",
  "hooks": {
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.preemdeck/scripts/preemdeck-bun \"${CLAUDE_PLUGIN_ROOT}/scripts/inject_mode.ts\" --event UserPromptSubmit",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
