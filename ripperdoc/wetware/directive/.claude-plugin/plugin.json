{
  "name": "directive",
  "description": "Swappable behavioral directive. A /directive command picks which directive a per-prompt hook injects as context.",
  "version": "0.1.0",
  "author": {
    "name": "preemdeck"
  },
  "keywords": [
    "wetware",
    "directive",
    "mode",
    "toggle",
    "behavior"
  ],
  "hooks": {
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/scripts/inject_mode.py --event UserPromptSubmit",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
