*.bak

# Environment / secrets
.env
.env.local
.env.*.local

# Logs
*.log

# Host CLIs (local-only overrides)
.claude/settings.local.json

# preemdeck user config — written from install.ts's built-in defaults on first install;
# gitignored so a re-install (fetch/reset) never reverts the user's directive edits
preemdeck.json

# preemdeck install manifest (generated per-install local state)
.install-manifest.json

# preemdeck shipped Bun runtime (fetched by boot.sh into ~/.preemdeck/.runtime)
.runtime/

# preemdeck primitives-only plugin mirror (rebuilt from src/ripperdoc/ each install)
.stage/

# JS/TS tooling (Bun)
node_modules/

# Editors
.idea/
.vscode/
*.swp
*.swo
*~

# OS — macOS
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes
.fseventsd
.TemporaryItems

# OS — Linux
.directory
.Trash-*
.nfs*
.fuse_hidden*
