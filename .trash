# Dev-only paths stripped from the deployed ~/.preemdeck clone by boot.sh
# (git sparse-checkout, gitignore-style patterns). None of this is needed to RUN
# preemdeck — only to develop it. This file must NOT list itself. See boot.sh.
/.github
/.claude
/.codex
/.gemini
/.prettierrc.json
/.prettierignore
/biome.json
/tsconfig.json
/llm-docs
# NOT /devscripts — it holds trash.ts (this prune's OWN tool, run from
# ~/.preemdeck by boot.sh) + format-on-edit.ts; the *.spec.ts pattern below
# still drops the dev tests there. Listing it would prune the prune. See boot.sh.
/AGENTS.md
/CLAUDE.md
*.test.ts
*.spec.ts
