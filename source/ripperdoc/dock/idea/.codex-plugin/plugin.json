{
  "name": "idea",
  "description": "Auto-open specs, briefs, and plans in the correct JetBrains IDE",
  "version": "0.0.0",
  "author": {
    "name": "preemdeck"
  },
  "keywords": [
    "dock",
    "jetbrains",
    "ide",
    "auto-open",
    "acp"
  ],
  "hooks": {
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.preemdeck/preemdeck-runtime \"$HOME/.preemdeck/source/ripperdoc/dock/idea/toolbox/turn-notify.ts\" Codex",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
