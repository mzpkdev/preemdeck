{
  "name": "directive",
  "description": "Swappable behavioral directive. A /directive command picks which directive a per-prompt hook injects as context.",
  "version": "0.0.0",
  "author": {
    "name": "preemdeck"
  },
  "keywords": [
    "wetware",
    "directive",
    "mode",
    "toggle",
    "behavior"
  ],
  "hooks": {
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.preemdeck/preemdeck-runtime \"$HOME/.preemdeck/source/ripperdoc/wetware/directive/scripts/inject-mode.ts\" --event UserPromptSubmit",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
