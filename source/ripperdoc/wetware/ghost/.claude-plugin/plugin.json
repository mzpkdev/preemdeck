{
  "name": "ghost",
  "description": "Persona engine. Injects engram, firmware, and pulse context on session start and each prompt.",
  "version": "0.0.0",
  "author": {
    "name": "preemdeck"
  },
  "keywords": [
    "wetware",
    "persona",
    "engram",
    "firmware",
    "identity",
    "ghost"
  ],
  "hooks": {
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.preemdeck/preemdeck-runtime \"$HOME/.preemdeck/source/ripperdoc/wetware/ghost/scripts/boot.ts\"",
            "timeout": 5
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.preemdeck/preemdeck-runtime \"$HOME/.preemdeck/source/ripperdoc/wetware/ghost/scripts/pulse.ts\"",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
